# Claude Auto-Debug user configuration
#
# Copy or install this file to:
#   ~/.config/claude-auto-debug/config.env
#
# Required: absolute path to the project that auto-debug should operate on.
PROJECT_DIR=

# Validation command run by the auto-debug workflow before or after changes.
VALIDATION_CMD="bash scripts/run-tests.sh"

# Comma-separated tool allowlist passed through to the auto-debug workflow.
ALLOWED_TOOLS=Read,Edit,Write,Glob,Grep,Bash

# Maximum number of files the workflow may modify in a single run.
MAX_FILES=3

# Number of days to retain workflow logs or artifacts, if supported by the runner.
LOG_RETENTION_DAYS=30

# Timer interval used by install.sh when rendering the systemd timer unit.
INTERVAL=6h
